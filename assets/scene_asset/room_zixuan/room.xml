<?xml version="1.0"?>
<mujoco model="Zixuan_room">

  <asset>
    <material name="room_floor_mat"    rgba="0.85 0.80 0.72 1"/>
    <material name="room_wall_mat"     rgba="1.00 1.00 1.00 0.25"/>
    <material name="room_black_mat"    rgba="0.12 0.12 0.12 1"/>
    <material name="room_yellow_mat"   rgba="1.00 0.85 0.10 1"/>
    <material name="room_white_mat"    rgba="0.95 0.95 0.95 1"/>
    <material name="room_fabric_blue"  rgba="0.25 0.38 0.60 1"/>
    <material name="room_wood_dark"    rgba="0.40 0.26 0.13 1"/>
    <material name="room_wood_light"   rgba="0.75 0.58 0.38 1"/>
  </asset>

  <worldbody>

    <!-- ===== Room structure (static, no body wrapper) ===== -->
    <!-- Floor: 5.3 m x 6 m (extended 0.3m in -x direction) -->
    <geom name="room_floor"       type="plane" size="2.65 3.0 0.1"   pos="-0.15 0 0"     material="room_floor_mat"/>
    <!-- Walls (0.1 m thick, 2.5 m tall) -->
    <geom name="room_wall_back"   type="box"   size="2.65 0.05 1.25" pos="-0.15  3.0  1.25"  material="room_wall_mat"/>
    <geom name="room_wall_front"  type="box"   size="2.65 0.05 1.25" pos="-0.15 -3.0  1.25"  material="room_wall_mat"/>
    <geom name="room_wall_left"   type="box"   size="0.05 3.0 1.25"  pos="-2.8 0   1.25" material="room_wall_mat"/>
    <geom name="room_wall_right"  type="box"   size="0.05 3.0 1.25"  pos=" 2.5 0   1.25" material="room_wall_mat"/>

    <!-- ===== Bed (back-left corner) — 50 kg ===== -->
    <body name="bed">
      <inertial mass="50" pos="-1.7 2.0 0.35" diaginertia="19.9 6.5 23.4"/>
      <geom name="room_bed_frame"     type="box" size="0.55 1.05 0.12" pos="-1.7 1.9 0.12" material="room_wood_dark"/>
      <geom name="room_bed_mattress"  type="box" size="0.50 0.95 0.12" pos="-1.7 1.9 0.36" material="room_yellow_mat"/>
      <geom name="room_bed_pillow"    type="box" size="0.22 0.15 0.06" pos="-1.7 2.8 0.50" material="room_white_mat"/>
      <geom name="room_bed_headboard" type="box" size="0.55 0.06 0.40" pos="-1.7 2.9 0.60" material="room_wood_dark"/>
    </body>

    <!-- ===== Desk (back-right corner) — 20 kg ===== -->
    <body name="desk">
      <inertial mass="20" pos="1.7 2.5 0.45" diaginertia="2.0 4.2 4.3"/>
      <geom name="room_desk_top"       type="box"      size="0.70 0.40 0.02" pos="1.7 2.5 0.74"  material="room_black_mat"/>
      <geom name="room_desk_leg_fl"    type="cylinder" size="0.025 0.36"     pos="1.05 2.12 0.36" material="room_black_mat"/>
      <geom name="room_desk_leg_fr"    type="cylinder" size="0.025 0.36"     pos="2.35 2.12 0.36" material="room_black_mat"/>
      <geom name="room_desk_leg_bl"    type="cylinder" size="0.025 0.36"     pos="1.05 2.88 0.36" material="room_black_mat"/>
      <geom name="room_desk_leg_br"    type="cylinder" size="0.025 0.36"     pos="2.35 2.88 0.36" material="room_black_mat"/>
      <geom name="room_monitor_stand"  type="box"      size="0.04 0.04 0.12" pos="1.7 2.65 0.88"  material="room_black_mat"/>
      <geom name="room_monitor_screen" type="box"      size="0.28 0.02 0.17" pos="1.7 2.67 1.09"  material="room_black_mat"/>
    </body>

    <!-- ===== Chair (in front of desk) — 5 kg ===== -->
    <body name="chair">
      <inertial mass="5" pos="1.7 1.85 0.35" diaginertia="0.27 0.27 0.13"/>
      <geom name="room_chair_seat"   type="box"      size="0.20 0.20 0.02" pos="1.7 1.9 0.46"   material="room_black_mat"/>
      <geom name="room_chair_back"   type="box"      size="0.20 0.03 0.22" pos="1.7 1.70 0.68"  material="room_black_mat"/>
      <geom name="room_chair_leg_fl" type="cylinder" size="0.02 0.22"      pos="1.52 1.72 0.22" material="room_black_mat"/>
      <geom name="room_chair_leg_fr" type="cylinder" size="0.02 0.22"      pos="1.88 1.72 0.22" material="room_black_mat"/>
      <geom name="room_chair_leg_bl" type="cylinder" size="0.02 0.22"      pos="1.52 2.08 0.22" material="room_black_mat"/>
      <geom name="room_chair_leg_br" type="cylinder" size="0.02 0.22"      pos="1.88 2.08 0.22" material="room_black_mat"/>
    </body>

    <!-- ===== Bookshelf (right wall) — 40 kg ===== -->
    <body name="bookshelf">
      <inertial mass="40" pos="1.27 -2.85 0.90" diaginertia="11.1 29.4 18.9"/>
      <geom name="room_shelf_side_l"  type="box" size="0.02 0.15 0.90" pos=" 0.09 -2.85 0.90" material="room_wood_dark"/>
      <geom name="room_shelf_side_r"  type="box" size="0.02 0.15 0.90" pos=" 2.45 -2.85 0.90" material="room_wood_dark"/>
      <geom name="room_shelf_board_0" type="box" size="1.20 0.15 0.02" pos=" 1.27 -2.85 0.20"  material="room_wood_light"/>
      <geom name="room_shelf_board_1" type="box" size="1.20 0.15 0.02" pos=" 1.27 -2.85 0.62"  material="room_wood_light"/>
      <geom name="room_shelf_board_2" type="box" size="1.20 0.15 0.02" pos=" 1.27 -2.85 1.04"  material="room_wood_light"/>
      <geom name="room_shelf_board_3" type="box" size="1.20 0.15 0.02" pos=" 1.27 -2.85 1.46"  material="room_wood_light"/>
      <geom name="room_shelf_top"     type="box" size="1.20 0.15 0.02" pos=" 1.27 -2.85 1.78"  material="room_wood_light"/>
      <geom name="room_book_0" type="box" size="0.025 0.10 0.09" pos=" 0.27 -2.85 0.33" material="room_fabric_blue"/>
      <geom name="room_book_1" type="box" size="0.025 0.10 0.10" pos=" 0.37 -2.85 0.34" material="room_wood_dark"/>
      <geom name="room_book_2" type="box" size="0.025 0.10 0.08" pos=" 0.67 -2.85 0.32" material="room_white_mat"/>
      <geom name="room_book_3" type="box" size="0.025 0.10 0.09" pos=" 1.27 -2.85 0.75" material="room_wood_dark"/>
      <geom name="room_book_4" type="box" size="0.025 0.10 0.11" pos=" 1.67 -2.85 0.76" material="room_fabric_blue"/>
      <geom name="room_book_5" type="box" size="0.025 0.10 0.09" pos=" 2.07 -2.85 0.33" material="room_white_mat"/>
      <geom name="room_book_6" type="box" size="0.025 0.10 0.10" pos=" 0.97 -2.85 1.17" material="room_fabric_blue"/>
      <geom name="room_book_7" type="box" size="0.025 0.10 0.09" pos=" 1.87 -2.85 1.18" material="room_wood_dark"/>
    </body>

    <!-- ===== Coffee table (center of room) — 10 kg ===== -->
    <body name="coffee_table">
      <inertial mass="10" pos="0 0 0.30" diaginertia="0.85 1.81 2.31"/>
      <geom name="room_table_top"    type="box"      size="0.70 0.45 0.02" pos="-1.3 -0.8 0.44"        material="room_wood_light"/>
      <geom name="room_table_leg_fl" type="cylinder" size="0.025 0.21"     pos="-1.94 -1.19 0.21" material="room_wood_dark"/>
      <geom name="room_table_leg_fr" type="cylinder" size="0.025 0.21"     pos="-0.66 -1.19 0.21" material="room_wood_dark"/>
      <geom name="room_table_leg_bl" type="cylinder" size="0.025 0.21"     pos="-1.94  -0.41 0.21" material="room_wood_dark"/>
      <geom name="room_table_leg_br" type="cylinder" size="0.025 0.21"     pos="-0.66  -0.41 0.21" material="room_wood_dark"/>
    </body>

    <!-- ===== Sofa (front-left area) — 60 kg ===== -->
    <body name="sofa">
      <inertial mass="60" pos="-1.2 -2.40 0.40" diaginertia="7.5 28.9 31.5"/>
      <geom name="room_sofa_base"  type="box" size="0.75 0.50 0.20" pos="-1.2 -2.3 0.20"  material="room_fabric_blue"/>
      <geom name="room_sofa_back"  type="box" size="1.15 0.08 0.48" pos="-1.2 -2.58 0.58" material="room_fabric_blue"/>
      <geom name="room_sofa_arm_l" type="box" size="0.68 0.50 0.10" pos="-1.7 -2.3 0.50"  material="room_fabric_blue"/>
      <geom name="room_sofa_arm_r" type="box" size="0.68 0.50 0.10" pos="-0.7 -2.3 0.50"  material="room_fabric_blue"/>
    </body>

    <!-- ===== Lights ===== -->
    <light name="room_ceiling_main"  pos=" 0.0  0.0 2.4" dir="0 0 -1" diffuse="1.8 1.8 1.7"   specular="0.4 0.4 0.4" castshadow="true"/>
    <light name="room_ceiling_left"  pos="-1.5  1.0 2.4" dir="0 0 -1" diffuse="0.8 0.8 0.75"  specular="0.1 0.1 0.1" castshadow="false"/>
    <light name="room_ceiling_right" pos=" 1.5 -1.0 2.4" dir="0 0 -1" diffuse="0.8 0.8 0.75"  specular="0.1 0.1 0.1" castshadow="false"/>

  </worldbody>

</mujoco>
